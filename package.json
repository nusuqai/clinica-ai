{
  "name": "clinica-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.hosted -- next dev",
    "dev:local": "dotenv -e .env.localdb -- next dev",
    "build": "next build",
    "build:local": "dotenv -e .env.localdb -- next build",
    "start": "next start",
    "start:local": "dotenv -e .env.localdb -- next start",
    "lint": "next lint",
    "prisma:generate": "dotenv -e .env.hosted -- prisma generate",
    "prisma:generate:local": "dotenv -e .env.localdb -- prisma generate",
    "prisma:migrate": "dotenv -e .env.hosted -- prisma migrate dev",
    "prisma:migrate:local": "dotenv -e .env.localdb -- prisma migrate dev",
    "prisma:push:local": "dotenv -e .env.localdb -- prisma db push",
    "prisma:deploy": "dotenv -e .env.hosted -- prisma migrate deploy",
    "prisma:deploy:local": "dotenv -e .env.localdb -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.hosted -- prisma studio",
    "prisma:studio:local": "dotenv -e .env.localdb -- prisma studio",
    "tunnel": "ngrok http 3000",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "lucide-react": "^0.575.0",
    "next": "^15.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
