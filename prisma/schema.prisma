generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum DayOfWeek {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum Channel {
  WEB
  WHATSAPP
}

enum SenderType {
  USER
  ADMIN
  AGENT
}

// ─── Models ───────────────────────────────────────────────────────────────────

// Mirrors auth.users — id is provided by Supabase Auth, not generated by Prisma
model Profile {
  id        String   @id @db.Uuid
  role      Role
  fullName  String
  phone     String?  @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor        Doctor?
  appointments  Appointment[]
  conversations Conversation[]
  sentMessages  Message[]      @relation("SenderProfile")

  @@map("profiles")
}

model Doctor {
  id              String   @id @db.Uuid
  specialty       String
  bio             String?
  consultationFee Decimal? @db.Decimal(10, 2)
  isActive        Boolean  @default(true)

  profile           Profile            @relation(fields: [id], references: [id], onDelete: Cascade)
  availabilityRules AvailabilityRule[]
  slots             Slot[]
  appointments      Appointment[]

  @@map("doctors")
}

model AvailabilityRule {
  id              String    @id @default(uuid()) @db.Uuid
  doctorId        String    @db.Uuid
  dayOfWeek       DayOfWeek
  startTime       String // "HH:MM" e.g. "14:00"
  endTime         String // "HH:MM" e.g. "17:00"
  slotDurationMin Int       @default(30)
  isActive        Boolean   @default(true)
  generatedUntil  DateTime? @db.Date // tracks how far ahead slots have been generated

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slots  Slot[]

  @@index([doctorId])
  @@map("availability_rules")
}

model Slot {
  id        String   @id @default(uuid()) @db.Uuid
  doctorId  String   @db.Uuid
  ruleId    String?  @db.Uuid
  date      DateTime @db.Date
  startTime DateTime
  endTime   DateTime
  isBlocked Boolean  @default(false)

  doctor      Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  rule        AvailabilityRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  appointment Appointment?

  @@index([doctorId, date])
  @@map("slots")
}

model Appointment {
  id                 String            @id @default(uuid()) @db.Uuid
  patientId          String            @db.Uuid
  doctorId           String            @db.Uuid
  slotId             String            @unique @db.Uuid
  status             AppointmentStatus @default(PENDING)
  patientNotes       String?
  doctorNotes        String?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  patient Profile @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  slot    Slot    @relation(fields: [slotId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@map("appointments")
}

model Conversation {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  whatsappPhone String?  @unique
  whatsappName  String?
  channel       Channel
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     Profile?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  sessions ChatSession[]

  @@unique([userId, channel])
  @@map("conversations")
}

// A bounded chat window (fixed 30-min from its first message) used to scope
// LLM context and to group messages with dividers in the admin inbox.
model ChatSession {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  startedAt      DateTime @default(now())
  expiresAt      DateTime // startedAt + 30 min

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([conversationId])
  @@map("chat_sessions")
}

model Message {
  id             String     @id @default(uuid()) @db.Uuid
  conversationId String     @db.Uuid
  sessionId      String?    @db.Uuid
  senderType     SenderType
  senderId       String?    @db.Uuid // null when senderType = AGENT
  content        String
  metadata       Json? // { toolCalls: [{ name, args, result, status }] } — set on AGENT messages that ran tools
  isRead         Boolean    @default(false)
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  session      ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sender       Profile?     @relation("SenderProfile", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([sessionId])
  @@map("messages")
}
