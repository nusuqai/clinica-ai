# Copy this to .env.hosted (pointed at your real Supabase project) and/or
# .env.localdb (pointed at `npx supabase start`'s local stack).
# Scripts pick the right one explicitly via dotenv-cli — see package.json.

# Supabase (Auth / Storage / Realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma) — point both at the NEW Supabase project
DATABASE_URL=        # pooled connection (PgBouncer, port 6543, ?pgbouncer=true) used by the app
DIRECT_URL=          # direct connection (port 5432) used by `prisma migrate`

# AI Agent (Phase 4)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# App URL — used to build the Evolution API webhook URL server-side
APP_URL=http://localhost:3000

# WhatsApp Cloud API (Phase 4)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_KEY=
EVOLUTION_INSTANCE_NAME=